Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Figure", " ", "13", " ", 
    RowBox[{"Replication", ":", " ", 
     RowBox[{"Suppress", " ", "+", " ", 
      RowBox[{"Inject", " ", "Position", " ", "Sweep"}]}]}]}], " ", "*)"}], 
  "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Llama", " ", "3.2", " ", "1", "B", " ", "with", " ", "524", "K", " ", 
    "CLT"}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Import", " ", "JSON", " ", "output", " ", "from", " ", "candle"}], "-", 
    RowBox[{"mi", " ", "figure13_planning", "_poems", " ", "example"}]}], " ",
    "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"llamaData", " ", "=", " ", 
     RowBox[{"Import", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"NotebookDirectory", "[", "]"}], ",", 
          " ", "\"\<llama_output.json\>\""}], "}"}], "]"}], ",", "\n", 
       "  ", "\"\<RawJSON\>\""}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"llamaSweep", " ", "=", " ", 
     RowBox[{"extractSweep", "[", "llamaData", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"llamaProbs", " ", "=", " ", 
     RowBox[{"llamaSweep", "[", "\"\<probs\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"llamaTokens", " ", "=", " ", 
     RowBox[{"llamaSweep", "[", "\"\<tokens\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"llamaBaseline", " ", "=", " ", 
     RowBox[{"llamaSweep", "[", "\"\<baseline\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"llamaLabels", " ", "=", " ", 
     RowBox[{"cleanToken", " ", "/@", " ", "llamaTokens"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Prepend", " ", "baseline", " ", "as", " ", "\"\<No Steering\>\"", " ", 
     "bar"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"llamaAllProbs", " ", "=", " ", 
     RowBox[{"Prepend", "[", 
      RowBox[{"llamaProbs", ",", " ", "llamaBaseline"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"llamaAllLabels", " ", "=", " ", 
     RowBox[{"Prepend", "[", 
      RowBox[{"llamaLabels", ",", " ", "\"\<No Steering\>\""}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{"nLlama", " ", "=", " ", 
    RowBox[{"Length", "[", "llamaAllProbs", "]"}]}]}]}]], "Input",
