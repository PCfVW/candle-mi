Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", 
    "==="}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"PART", " ", "2"}], ":", " ", 
    RowBox[{"Gemma", " ", "2", " ", "2", "B"}]}], 
   "                                                 ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
     "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", 
    "==="}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"gemmaData", " ", "=", " ", 
     RowBox[{"Import", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"NotebookDirectory", "[", "]"}], ",", 
          " ", "\"\<gemma_output.json\>\""}], "}"}], "]"}], ",", "\n", 
       "  ", "\"\<RawJSON\>\""}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"gemmaSweep", " ", "=", " ", 
     RowBox[{"extractSweep", "[", "gemmaData", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gemmaProbs", " ", "=", " ", 
     RowBox[{"gemmaSweep", "[", "\"\<probs\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gemmaTokens", " ", "=", " ", 
     RowBox[{"gemmaSweep", "[", "\"\<tokens\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gemmaBaseline", " ", "=", " ", 
     RowBox[{"gemmaSweep", "[", "\"\<baseline\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gemmaLabels", " ", "=", " ", 
     RowBox[{"cleanToken", " ", "/@", " ", "gemmaTokens"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Prepend", " ", "baseline", " ", "as", " ", "\"\<No Steering\>\"", " ", 
     "bar"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"gemmaAllProbs", " ", "=", " ", 
     RowBox[{"Prepend", "[", 
      RowBox[{"gemmaProbs", ",", " ", "gemmaBaseline"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gemmaAllLabels", " ", "=", " ", 
     RowBox[{"Prepend", "[", 
      RowBox[{"gemmaLabels", ",", " ", "\"\<No Steering\>\""}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{"nGemma", " ", "=", " ", 
    RowBox[{"Length", "[", "gemmaAllProbs", "]"}]}]}]}]], "Input",
